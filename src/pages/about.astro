---
import Layout from '../layouts/Layout.astro';
import Container from '../components/atoms/Container.astro';
import Text from '../components/atoms/Text.astro';
---

<Layout>
  <slot name="head">
    <title>About — virtoza.daily</title>
  </slot>

  <Container class="py-12 space-y-4">
    <Text as="h1" size="2xl" weight="700">About</Text>
    <Text as="p" size="sm" class="text-neutral-500">
      Built with Astro, Tailwind CSS, Drizzle (Neon), and Lucide.
    </Text>
  </Container>
</Layout>
